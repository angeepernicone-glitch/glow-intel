---
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  imageAlt?: string;
  type?: 'website' | 'article';
  pubDate?: Date;
  updatedDate?: Date;
}

const { title, description, image, imageAlt, type, pubDate, updatedDate } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <SEOHead
      title={title}
      description={description}
      image={image}
      imageAlt={imageAlt}
      type={type}
      pubDate={pubDate}
      updatedDate={updatedDate}
    />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
