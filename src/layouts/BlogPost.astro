---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  heroImageAlt?: string;
  category: string;
  tags: string[];
}

const { title, description, pubDate, updatedDate, heroImage, heroImageAlt, category, tags } = Astro.props;

const categoryLabels: Record<string, string> = {
  'ingredients': 'Ingredients',
  'routines': 'Routines',
  'reviews': 'Reviews',
  'versus': 'Versus',
  'beauty-business': 'Beauty Business',
  'beginner-guides': 'Beginner Guides',
};

const formattedDate = pubDate.toLocaleDateString('en-US', {
  month: 'long', day: 'numeric', year: 'numeric',
});

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": pubDate.toISOString(),
  "dateModified": (updatedDate || pubDate).toISOString(),
  "publisher": { "@type": "Organization", "name": "Glow Intel", "url": Astro.site?.href },
  "image": heroImage ? new URL(heroImage, Astro.site).href : undefined,
  "mainEntityOfPage": { "@type": "WebPage", "@id": Astro.url.href },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": Astro.site?.href },
    { "@type": "ListItem", "position": 2, "name": categoryLabels[category] || category, "item": new URL(`/categories/${category}`, Astro.site).href },
    { "@type": "ListItem", "position": 3, "name": title },
  ],
};
---

<BaseLayout title={title} description={description} image={heroImage} imageAlt={heroImageAlt} type="article" pubDate={pubDate} updatedDate={updatedDate}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Hero image — responsive aspect ratio -->
  {heroImage && (
    <div class="w-full overflow-hidden" style="aspect-ratio: 21/8; min-height: 200px; background: var(--bg-alt)">
      <img
        src={heroImage}
        alt={heroImageAlt || title}
        class="w-full h-full object-cover"
        loading="eager"
      />
    </div>
  )}

  <!-- Mobile meta strip -->
  <div class="lg:hidden border-b border-[var(--border-light)]" style="background: white;">
    <div class="max-w-7xl mx-auto px-5 py-4 flex items-center gap-3 flex-wrap">
      <a href="/" class="eyebrow no-underline hover:text-[var(--accent)]">Home</a>
      <span class="eyebrow">/</span>
      <a href={`/categories/${category}`} class="eyebrow accent no-underline">{categoryLabels[category] || category}</a>
      <span style="flex:1"></span>
      <time class="eyebrow" datetime={pubDate.toISOString()}>{formattedDate}</time>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-5 sm:px-8 py-10 lg:py-12">
    <div class="grid lg:grid-cols-[1fr_2fr] gap-12 lg:gap-20">

      <!-- ─── Left sidebar (sticky meta, desktop only) ───────────────── -->
      <aside class="hidden lg:block lg:sticky lg:top-24 lg:self-start">
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 mb-8">
          <a href="/" class="eyebrow no-underline hover:text-[var(--accent)] transition-colors">Home</a>
          <span class="eyebrow">/</span>
          <a href={`/categories/${category}`} class="eyebrow accent no-underline hover:opacity-70 transition-opacity">
            {categoryLabels[category] || category}
          </a>
        </nav>

        <div class="rule-accent mb-6"></div>

        <!-- Category -->
        <a href={`/categories/${category}`} class="eyebrow accent no-underline block mb-4">
          {categoryLabels[category] || category}
        </a>

        <!-- Date -->
        <time class="eyebrow block mb-2" datetime={pubDate.toISOString()}>{formattedDate}</time>

        {updatedDate && (
          <span class="eyebrow block mb-6">
            Updated {updatedDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
          </span>
        )}

        <!-- Tags -->
        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-6">
            {tags.map(tag => (
              <span class="text-xs px-3 py-1 border border-[var(--border)] rounded-full" style="color: var(--text-muted)">
                {tag}
              </span>
            ))}
          </div>
        )}

        <!-- Back to top -->
        <button
          id="back-to-top"
          class="flex items-center gap-2 mt-12 eyebrow hover:text-[var(--accent)] transition-colors cursor-pointer"
          onclick="window.scrollTo({top: 0, behavior: 'smooth'})"
        >
          ↑ Back to top
        </button>
      </aside>

      <!-- ─── Main content ──────────────────────────────── -->
      <article>
        <!-- Title -->
        <h1 style="font-family: var(--serif); font-weight: 900; font-size: clamp(1.875rem, 4vw, 3rem); line-height: 1.1; letter-spacing: -0.01em; color: var(--text);" class="mb-8 reveal">
          {title}
        </h1>

        <!-- Lead paragraph (description as lede) -->
        <p style="font-family: var(--serif); font-size: 1.1875rem; line-height: 1.65; color: var(--text-muted); border-left: 2px solid var(--accent); padding-left: 1.25rem;" class="mb-10 reveal reveal-delay-1">
          {description}
        </p>

        <div class="rule mb-10 reveal reveal-delay-2"></div>

        <!-- Post body -->
        <div class="prose reveal reveal-delay-3">
          <slot />
        </div>
      </article>
    </div>
  </div>
</BaseLayout>
