---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sorted = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const hero = sorted[0];
const featured = sorted.slice(1, 4);
const recent = sorted.slice(4, 10);

// Calculate reading time (words / 200 = minutes)
function getReadingTime(body: string): number {
  const words = body.split(/\s+/).length;
  return Math.max(1, Math.round(words / 200));
}

const categories = [
  { slug: 'ingredients', label: 'Ingredients', icon: '&#9878;' },
  { slug: 'routines', label: 'Routines', icon: '&#9681;' },
  { slug: 'versus', label: 'Versus', icon: '&#9878;' },
  { slug: 'reviews', label: 'Reviews', icon: '&#9733;' },
  { slug: 'beauty-business', label: 'Business', icon: '&#9830;' },
  { slug: 'beginner-guides', label: 'Start Here', icon: '&#10148;' },
];

const heroReadTime = hero ? getReadingTime(hero.body || '') : 0;
---

<BaseLayout
  title="Glow Intel — Honest Skincare Intel"
  description="Honest skincare intel without the marketing speak. Ingredient deep dives, product reviews, and beauty business insights."
>
  <!-- Organization schema for homepage -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Glow Intel",
    "url": Astro.site?.href || "https://glowintel.com",
    "description": "Honest skincare intel without the marketing speak. Ingredient deep dives, product reviews, and beauty business insights.",
    "publisher": {
      "@type": "Organization",
      "name": "Glow Intel"
    }
  })} />

  <!-- ─── HERO POST ────────────────────────────────────── -->
  {hero && (
    <section class="max-w-7xl mx-auto px-5 sm:px-8 pt-10 pb-10">
      <a href={`/blog/${hero.id}`} class="no-underline group block">
        <div class="grid lg:grid-cols-2 gap-8 lg:gap-14 items-center">

          <!-- Image -->
          <div class="aspect-[16/10] rounded-lg overflow-hidden img-zoom reveal" style="background: var(--bg-alt)">
            {hero.data.heroImage ? (
              <img
                src={hero.data.heroImage}
                alt={hero.data.heroImageAlt || hero.data.title}
                class="w-full h-full object-cover"
                loading="eager"
              />
            ) : (
              <div class="w-full h-full flex items-center justify-center">
                <span class="text-6xl" style="color: var(--border)">&#10022;</span>
              </div>
            )}
          </div>

          <!-- Text -->
          <div class="reveal reveal-delay-2">
            <div class="flex items-center gap-3 mb-3">
              <span class="eyebrow accent">
                {hero.data.category.replace(/-/g, ' ')}
              </span>
              <span class="badge trending">Latest</span>
              <span class="badge">{heroReadTime} min read</span>
            </div>
            <h1 style="font-family: var(--serif); font-weight: 900; font-size: clamp(2rem, 4vw, 3.25rem); line-height: 1.1; letter-spacing: -0.01em; color: var(--text);" class="group-hover:text-[var(--accent)] transition-colors duration-300 mb-5">
              {hero.data.title}
            </h1>
            <p class="text-base leading-relaxed mb-6" style="color: var(--text-muted); max-width: 46ch">
              {hero.data.description}
            </p>
            <span class="cta-pill filled">
              Read the full story &rarr;
            </span>
          </div>
        </div>
      </a>
    </section>
  )}

  <div class="rule max-w-7xl mx-auto"></div>

  <!-- ─── FEATURED GRID (3 cards) ─────────────────────── -->
  {featured.length > 0 && (
    <section class="max-w-7xl mx-auto px-5 sm:px-8 py-12">
      <div class="flex items-center gap-4 mb-8 reveal">
        <h2 class="eyebrow accent" style="white-space: nowrap;">Editor's Picks</h2>
        <div class="flex-1 h-px" style="background: var(--border)"></div>
        <a href="/blog" class="cta-pill" style="flex-shrink: 0;">View all</a>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-8">
        {featured.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            slug={post.id}
            pubDate={post.data.pubDate}
            category={post.data.category}
            heroImage={post.data.heroImage}
            heroImageAlt={post.data.heroImageAlt}
            variant="default"
            readingTime={getReadingTime(post.body || '')}
          />
        ))}
      </div>
    </section>
  )}

  <div class="rule max-w-7xl mx-auto"></div>

  <!-- ─── CATEGORIES + KEEP READING (white bg) ────────── -->
  <div style="background: white;">
  <section class="max-w-7xl mx-auto px-5 sm:px-8 py-10">
    <div class="flex items-baseline gap-4 mb-6 reveal">
      <h2 class="eyebrow">Explore Topics</h2>
      <div class="flex-1 h-px" style="background: var(--border)"></div>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3 reveal reveal-delay-1">
      {categories.map(cat => (
        <a
          href={`/categories/${cat.slug}`}
          class="no-underline flex flex-col items-center gap-2 py-5 px-3 border border-[var(--border)] rounded-lg text-center hover:border-[var(--accent)] hover:bg-[var(--accent-light)] transition-all duration-200 group"
          style="background: white;"
        >
          <span class="text-sm font-medium tracking-wide uppercase group-hover:text-[var(--accent)] transition-colors" style="color: var(--text-muted); font-family: var(--sans); font-size: 0.6875rem; letter-spacing: 0.1em;">
            {cat.label}
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- ─── MORE POSTS (numbered list) ─────────────────── -->
  {recent.length > 0 && (
    <section class="max-w-7xl mx-auto px-5 sm:px-8 py-10 border-t border-[var(--border)]">
      <div class="flex items-center gap-4 mb-6 reveal">
        <h2 class="eyebrow">Keep Reading</h2>
        <div class="flex-1 h-px" style="background: var(--border)"></div>
        <a href="/blog" class="cta-pill" style="flex-shrink: 0;">All posts</a>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-0">
        {recent.map((post, i) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            slug={post.id}
            pubDate={post.data.pubDate}
            category={post.data.category}
            heroImage={post.data.heroImage}
            heroImageAlt={post.data.heroImageAlt}
            variant="horizontal"
            readingTime={getReadingTime(post.body || '')}
            index={i + 1}
          />
        ))}
      </div>
    </section>
  )}

  </div><!-- end white bg wrapper -->

  <!-- ─── CLOSING STRIP ──────────────────────────────── -->
  <section class="border-t border-[var(--border)] mt-4" style="background: white;">
    <div class="max-w-7xl mx-auto px-5 sm:px-8 py-16">
      <div class="max-w-xl mx-auto text-center reveal">
        <div class="rule-accent mx-auto mb-6"></div>
        <p style="font-family: var(--serif); font-size: clamp(1.25rem, 2.5vw, 1.625rem); font-weight: 400; line-height: 1.5; color: var(--text);">
          Honest skincare intel. No brand deals, no sponsored reviews, no filler. Just what the science says and what actually works.
        </p>
        <a href="/blog" class="cta-pill filled mt-8 inline-flex">Browse all posts</a>
      </div>
    </div>
  </section>
</BaseLayout>
