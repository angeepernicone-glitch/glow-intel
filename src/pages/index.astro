---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featuredPost = sortedPosts[0];
const recentPosts = sortedPosts.slice(1, 7);

const categories = [
  { slug: 'ingredients', label: 'Ingredients', desc: 'What actually works — and why' },
  { slug: 'routines', label: 'Routines', desc: 'By skin type, age, and concern' },
  { slug: 'versus', label: 'Versus', desc: 'Direct comparisons, no fluff' },
  { slug: 'reviews', label: 'Reviews', desc: 'Honest takes on real products' },
  { slug: 'beauty-business', label: 'Beauty Business', desc: 'Ecommerce, trends, brand strategy' },
  { slug: 'beginner-guides', label: 'Start Here', desc: 'New to skincare? Begin here' },
];
---

<BaseLayout
  title="Glow Intel"
  description="Honest skincare intel without the marketing speak. Ingredient deep dives, product reviews, and beauty business insights — all backed by science."
>
  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pt-16 pb-12">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-widest mb-3" style="color: var(--color-accent)">
        Skincare · Beauty · Ecommerce
      </p>
      <h1 class="text-4xl sm:text-5xl font-bold leading-tight text-[var(--color-text)] mb-5">
        Skincare intel, zero fluff.
      </h1>
      <p class="text-lg text-[var(--color-muted)] leading-relaxed">
        Ingredient science, honest product takes, and beauty ecommerce insights. No brand deals. No filler. Just what you actually need to know.
      </p>
    </div>
  </section>

  <!-- Featured post -->
  {featuredPost && (
    <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-16">
      <a href={`/blog/${featuredPost.id}`} class="no-underline group block">
        <div class="grid md:grid-cols-2 gap-8 items-center p-6 sm:p-8 rounded-2xl bg-[var(--color-accent-light)]">
          {featuredPost.data.heroImage && (
            <div class="aspect-[4/3] rounded-xl overflow-hidden">
              <img
                src={featuredPost.data.heroImage}
                alt={featuredPost.data.heroImageAlt || featuredPost.data.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="eager"
              />
            </div>
          )}
          <div class={featuredPost.data.heroImage ? '' : 'md:col-span-2'}>
            <p class="text-xs font-semibold uppercase tracking-wider mb-2" style="color: var(--color-accent)">
              Featured
            </p>
            <h2 class="text-2xl sm:text-3xl font-bold text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors leading-tight mb-3">
              {featuredPost.data.title}
            </h2>
            <p class="text-[var(--color-muted)] leading-relaxed mb-4">
              {featuredPost.data.description}
            </p>
            <span class="text-sm font-medium" style="color: var(--color-accent)">
              Read more →
            </span>
          </div>
        </div>
      </a>
    </section>
  )}

  <!-- Recent posts -->
  {recentPosts.length > 0 && (
    <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-16">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-xl font-bold">Latest</h2>
        <a href="/blog" class="text-sm font-medium no-underline hover:opacity-80" style="color: var(--color-accent)">
          View all →
        </a>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {recentPosts.map(post => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            slug={post.id}
            pubDate={post.data.pubDate}
            category={post.data.category}
            heroImage={post.data.heroImage}
            heroImageAlt={post.data.heroImageAlt}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Categories -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-20">
    <h2 class="text-xl font-bold mb-8">Browse by Topic</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
      {categories.map(cat => (
        <a
          href={`/categories/${cat.slug}`}
          class="no-underline group p-5 rounded-xl border border-[var(--color-border)] hover:border-[var(--color-accent)] transition-colors"
        >
          <h3 class="font-bold text-sm text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors mb-1">
            {cat.label}
          </h3>
          <p class="text-xs text-[var(--color-muted)]">{cat.desc}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
