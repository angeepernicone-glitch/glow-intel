---
interface Props {
  title: string;
  description: string;
  slug: string;
  pubDate: Date;
  category: string;
  heroImage?: string;
  heroImageAlt?: string;
}

const { title, description, slug, pubDate, category, heroImage, heroImageAlt } = Astro.props;

const categoryLabels: Record<string, string> = {
  'ingredients': 'Ingredients',
  'routines': 'Routines',
  'reviews': 'Reviews',
  'versus': 'Versus',
  'beauty-business': 'Beauty Business',
  'beginner-guides': 'Beginner Guides',
};

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group">
  <a href={`/blog/${slug}`} class="no-underline block">
    {heroImage && (
      <div class="aspect-[16/9] rounded-lg overflow-hidden mb-4 bg-[var(--color-accent-light)]">
        <img
          src={heroImage}
          alt={heroImageAlt || title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
          loading="lazy"
        />
      </div>
    )}
    {!heroImage && (
      <div class="aspect-[16/9] rounded-lg overflow-hidden mb-4 bg-[var(--color-accent-light)] flex items-center justify-center">
        <span class="text-4xl opacity-30">✦</span>
      </div>
    )}

    <div>
      <div class="flex items-center gap-2 mb-2">
        <span class="text-xs font-medium uppercase tracking-wider" style="color: var(--color-accent)">
          {categoryLabels[category] || category}
        </span>
        <span class="text-[var(--color-border)]">·</span>
        <time class="text-xs text-[var(--color-muted)]" datetime={pubDate.toISOString()}>
          {formattedDate}
        </time>
      </div>

      <h2 class="font-bold text-lg leading-snug text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors mb-2">
        {title}
      </h2>

      <p class="text-sm text-[var(--color-muted)] leading-relaxed line-clamp-2">
        {description}
      </p>
    </div>
  </a>
</article>
