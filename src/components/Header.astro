---
const navLinks = [
  { href: '/categories/ingredients', label: 'Ingredients' },
  { href: '/categories/routines', label: 'Routines' },
  { href: '/categories/versus', label: 'Versus' },
  { href: '/categories/reviews', label: 'Reviews' },
  { href: '/categories/beauty-business', label: 'Business' },
  { href: '/categories/beginner-guides', label: 'Start Here' },
];

const currentPath = Astro.url.pathname;
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <!-- Top accent bar -->
  <div style="height: 3px; background: linear-gradient(90deg, var(--accent), var(--accent-hover), var(--accent));"></div>

  <div class="border-b border-[var(--border)] bg-white/97 backdrop-blur-md">
    <div class="max-w-7xl mx-auto px-5 sm:px-8">

      <!-- Logo row -->
      <div class="flex items-center justify-center py-4 border-b border-[var(--border-light)]">
        <a href="/" class="no-underline">
          <span style="font-family: var(--serif); font-size: 2.25rem; font-weight: 900; letter-spacing: -0.02em; color: var(--text); line-height: 1;">
            GLOW<span style="color: var(--accent);">INTEL</span>
          </span>
          <span class="block text-center" style="font-family: var(--sans); font-size: 0.625rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text-muted); margin-top: 2px;">
            Beauty &middot; Skincare &middot; Business
          </span>
        </a>

        <!-- Mobile hamburger -->
        <button
          id="mobile-menu-btn"
          class="lg:hidden p-2 absolute right-5 text-[var(--text)] hover:text-[var(--accent)] transition-colors"
          aria-label="Toggle menu"
        >
          <svg id="icon-open" width="22" height="16" viewBox="0 0 22 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="0" y1="2" x2="22" y2="2"/>
            <line x1="0" y1="8" x2="22" y2="8"/>
            <line x1="0" y1="14" x2="22" y2="14"/>
          </svg>
          <svg id="icon-close" class="hidden" width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="2" y1="2" x2="16" y2="16"/>
            <line x1="16" y1="2" x2="2" y2="16"/>
          </svg>
        </button>
      </div>

      <!-- Nav row (desktop) -->
      <nav class="hidden lg:flex items-center justify-center gap-1 py-2">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`nav-link no-underline px-4 py-2 rounded transition-colors duration-200 ${
              currentPath.startsWith(link.href) ? 'active' : ''
            }`}
          >
            {link.label}
          </a>
        ))}
        <a href="/blog" class="nav-link no-underline px-4 py-2 rounded transition-colors duration-200">All Posts</a>
      </nav>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-white border-b border-[var(--border)] shadow-lg">
    <div class="max-w-7xl mx-auto px-5 py-6 flex flex-col gap-1">
      {[...navLinks, { href: '/blog', label: 'All Posts' }].map(link => (
        <a href={link.href} class="no-underline py-3 px-4 rounded-lg hover:bg-[var(--accent-light)] transition-colors" style="font-family: var(--sans); font-size: 0.9375rem; font-weight: 500; color: var(--text);">
          {link.label}
        </a>
      ))}
    </div>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-28 lg:h-32"></div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
  });

  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    header?.classList.toggle('shadow-md', window.scrollY > 8);
  }, { passive: true });
</script>
