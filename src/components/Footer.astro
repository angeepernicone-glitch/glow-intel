---
const year = new Date().getFullYear();
---

<footer style="border-top: 1px solid var(--border); background: var(--bg);" class="mt-20">
  <!-- Top strip -->
  <div class="max-w-7xl mx-auto px-5 sm:px-8 py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">

      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="no-underline block mb-3">
          <span style="font-family: var(--serif); font-size: 1.25rem; font-weight: 900; color: var(--text);">
            GLOW<span style="color: var(--accent);">INTEL</span>
          </span>
        </a>
        <p class="text-xs leading-relaxed" style="color: var(--text-muted); max-width: 22ch">
          Honest skincare intel. No brand deals. No filler.
        </p>
      </div>

      <!-- Topics -->
      <div>
        <p class="eyebrow mb-4">Topics</p>
        <ul class="space-y-2">
          {[
            ['Ingredients', '/categories/ingredients'],
            ['Routines', '/categories/routines'],
            ['Versus', '/categories/versus'],
            ['Reviews', '/categories/reviews'],
          ].map(([label, href]) => (
            <li>
              <a href={href} class="text-xs no-underline hover:text-[var(--accent)] transition-colors" style="color: var(--text-muted)">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- More -->
      <div>
        <p class="eyebrow mb-4">More</p>
        <ul class="space-y-2">
          {[
            ['Beauty Business', '/categories/beauty-business'],
            ['Beginner Guides', '/categories/beginner-guides'],
            ['All Posts', '/blog'],
            ['About', '/about'],
          ].map(([label, href]) => (
            <li>
              <a href={href} class="text-xs no-underline hover:text-[var(--accent)] transition-colors" style="color: var(--text-muted)">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Meta -->
      <div>
        <p class="eyebrow mb-4">Meta</p>
        <ul class="space-y-2">
          {[
            ['RSS Feed', '/rss.xml'],
            ['Sitemap', '/sitemap-index.xml'],
          ].map(([label, href]) => (
            <li>
              <a href={href} class="text-xs no-underline hover:text-[var(--accent)] transition-colors" style="color: var(--text-muted)">{label}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div style="border-top: 1px solid var(--border-light);">
    <div class="max-w-7xl mx-auto px-5 sm:px-8 py-4 flex items-center justify-between">
      <p class="eyebrow">&copy; {year} Glow Intel</p>
      <p class="eyebrow">Science-first skincare</p>
    </div>
  </div>
</footer>
