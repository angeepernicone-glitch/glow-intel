---
const year = new Date().getFullYear();
---

<footer style="border-top: 1px solid var(--border); background: #1A1A1A;" class="mt-20">
  <div class="max-w-7xl mx-auto px-5 sm:px-8 py-14">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10">

      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="no-underline block mb-4">
          <span style="font-family: var(--serif); font-size: 1.375rem; font-weight: 900; color: white;">
            GLOW<span style="color: var(--accent);">INTEL</span>
          </span>
        </a>
        <p class="leading-relaxed" style="color: #9B9B9B; max-width: 28ch; font-size: 0.875rem;">
          Your daily source for skincare science, beauty business intel, and supplement insights.
        </p>
      </div>

      <!-- Topics -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider mb-5" style="color: white;">Topics</p>
        <ul class="space-y-3">
          {[
            ['Ingredients', '/categories/ingredients'],
            ['Routines', '/categories/routines'],
            ['Versus', '/categories/versus'],
            ['Reviews', '/categories/reviews'],
          ].map(([label, href]) => (
            <li>
              <a href={href} class="no-underline hover:text-[var(--accent)] transition-colors" style="color: #9B9B9B; font-size: 0.875rem;">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- More -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider mb-5" style="color: white;">More</p>
        <ul class="space-y-3">
          {[
            ['Beauty Business', '/categories/beauty-business'],
            ['Beginner Guides', '/categories/beginner-guides'],
            ['All Posts', '/blog'],
          ].map(([label, href]) => (
            <li>
              <a href={href} class="no-underline hover:text-[var(--accent)] transition-colors" style="color: #9B9B9B; font-size: 0.875rem;">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Meta -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider mb-5" style="color: white;">Meta</p>
        <ul class="space-y-3">
          {[
            ['RSS Feed', '/rss.xml'],
            ['Sitemap', '/sitemap-index.xml'],
          ].map(([label, href]) => (
            <li>
              <a href={href} class="no-underline hover:text-[var(--accent)] transition-colors" style="color: #9B9B9B; font-size: 0.875rem;">{label}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Legal links -->
    <div class="mt-10 pt-6" style="border-top: 1px solid #2a2a2a;">
      <ul class="flex flex-wrap gap-x-6 gap-y-2">
        {[
          ['Privacy Policy', '/privacy'],
          ['Disclaimer', '/disclaimer'],
          ['Affiliate Disclosure', '/affiliate-disclosure'],
        ].map(([label, href]) => (
          <li>
            <a href={href} class="no-underline hover:text-[var(--accent)] transition-colors text-xs" style="color: #666;">{label}</a>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Bottom bar -->
  <div style="border-top: 1px solid #333;">
    <div class="max-w-7xl mx-auto px-5 sm:px-8 py-4 flex items-center justify-between">
      <p class="text-xs" style="color: #666;">&copy; {year} Glow Intel</p>
      <p class="text-xs" style="color: #666;">Skincare &middot; Business &middot; Beauty</p>
    </div>
  </div>
</footer>
